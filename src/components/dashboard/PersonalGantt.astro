---
// к°ңмқё к°„нҠё (spec В§2 н•ҷмғқ мғҒм„ё в‘Ұ; mockup gantt() L653-678).
// л¶„кё°(3к°ңмӣ”) лҲҲкёҲ + м№ҙн…Ңкі лҰ¬мғү л§үлҢҖ(м—°кө¬=нҢҢлһ‘ --c-res В· н•ҷнҡҢ=мЈјнҷ© --c-conf В· нҲ¬кі =мҙҲлЎқ --c-jour В· мӢ¬мӮ¬=л¶„нҷҚ --c-rev)
// + мҡ°мёЎ лқјлІЁ(вҡ =ліҙм • note). мҳӨлҠҳм„ мқҖ нҒҙлқјмқҙм–ёнҠёк°Җ SVGм—җ м¶”к°Җ(лҰ¬л№Ңл“ң м—Ҷмқҙ мөңмӢ  мң м§Җ) вҖ” student-detail.ts.
// л¶Җл¶„ лӮ м§ң(YYYY-MM)лҠ” parseDate/parseDateEndлЎң мІҳлҰ¬(л§үлҢҖ лҒқмқҖ мӣ”л§җ). лӘЁл°”мқј к°ҖлЎң мҠӨнҒ¬лЎӨмқҖ л°”к№Ҙ `.gwrap`(нҺҳмқҙм§Җк°Җ к°җмҢҲ).
// мғүмғҒмқҖ CSS ліҖмҲҳ(style="fill:var(--x)")лЎң м§Җм • вҖ” н”„л Ҳм  н…Ңмқҙм…ҳ мҶҚм„ұ var() лҜём§Җмӣҗ мқҙмҠҲ нҡҢн”ј.
import { parseDate, parseDateEnd } from '../../lib/dates';
type CatKey = 'R' | 'C' | 'J' | 'D';
interface Sched {
  t: CatKey;
  n: string;
  s: string;
  e: string;
  fix?: string;
}
interface Props {
  sched: Sched[];
}
const { sched } = Astro.props;

const catVar: Record<CatKey, string> = {
  R: '--c-res',
  C: '--c-conf',
  J: '--c-jour',
  D: '--c-rev',
};

// в”Җв”Җ кө¬к°„ кі„мӮ° (mockup L655-657) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
const min = new Date(Math.min(...sched.map((r) => parseDate(r.s).getTime())));
min.setDate(1);
const max = new Date(Math.max(...sched.map((r) => parseDateEnd(r.e).getTime())));
max.setMonth(max.getMonth() + 1);
const minT = min.getTime();
const span = max.getTime() - minT;

const W = Math.max(680, Math.round(span / 86400000 / 2.2));
const LP = 6;
const RH = 26;
const TOP = 26;
const H = TOP + sched.length * RH + 14;
const SVGW = W + 330; // мҡ°мёЎ лқјлІЁ м—¬л°ұ
const x = (ms: number) => LP + ((ms - minT) / span) * (W - LP - 6);

// в”Җв”Җ л¶„кё° лҲҲкёҲ (mockup L661-667) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
const ticks: { xx: number; label: string }[] = [];
const q = new Date(min);
q.setMonth(Math.floor(q.getMonth() / 3) * 3, 1);
for (let d = new Date(q); d < max; d.setMonth(d.getMonth() + 3)) {
  const xx = x(d.getTime());
  if (xx < LP) continue;
  ticks.push({
    xx,
    label: `${String(d.getFullYear()).slice(2)}.${Math.floor(d.getMonth() / 3) + 1}Q`,
  });
}

// в”Җв”Җ л§үлҢҖ (mockup L668-673) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
const t = new Date();
const nowday = new Date(t.getFullYear(), t.getMonth(), t.getDate()).getTime();
const bars = sched.map((r, i) => {
  const y = TOP + i * RH;
  const x1 = x(parseDate(r.s).getTime());
  const x2 = Math.max(x(parseDateEnd(r.e).getTime()), x1 + 6);
  const active = parseDate(r.s).getTime() <= nowday && nowday <= parseDateEnd(r.e).getTime();
  return {
    y,
    x1,
    x2,
    w: x2 - x1,
    style: `fill:var(${catVar[r.t]});opacity:${active ? 1 : 0.82}`,
    tip: `${r.n} В· ${r.s} ~ ${r.e}${r.fix ? ` (${r.fix})` : ''}`,
    label: `${r.n}${r.fix ? ' вҡ ' : ''}`,
  };
});
---

<svg
  width={SVGW}
  height={H}
  viewBox={`0 0 ${SVGW} ${H}`}
  data-gantt
  data-min={minT}
  data-span={span}
  data-w={W}
  data-lp={LP}
  data-top={TOP}
  data-h={H}
>
  {ticks.map((tk) => <line x1={tk.xx} y1={TOP - 8} x2={tk.xx} y2={H - 10} class="gline" />)}
  {ticks.map((tk) => (
    <text x={tk.xx + 3} y={TOP - 12} class="axis num">
      {tk.label}
    </text>
  ))}
  {bars.map((b) => (
    <rect x={b.x1} y={b.y + 5} width={b.w} height="13" rx="4" style={b.style} data-tip={b.tip} />
  ))}
  {bars.map((b) => (
    <text x={b.x2 + 6} y={b.y + 15} class="bar-label" style="fill:var(--ink)">
      {b.label}
    </text>
  ))}
</svg>
