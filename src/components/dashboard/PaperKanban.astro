---
// 5-stage kanban for /papers (spec §2 PaperKanban, mock:818-832). STATIC render only —
// no drag/drop, no inline edit (Phase 3). Cards carry data-id / data-status (+ data-stu /
// data-tier / data-year) so Phase 3 can attach DnD and the client filter can show/hide them.
// Each column has a hidden `.kempty` the client reveals when a filter empties the column.
import TierBadge from './TierBadge.astro';
import StatusBadge from './StatusBadge.astro';

interface Paper {
  id: string;
  stu: string;
  t: string;
  tier: string;
  jr: string;
  st: string;
  stEn: string;
  sub?: string;
  note?: string;
}
interface Props {
  /** real papers only (kind === "실제") */
  papers: Paper[];
}
const { papers } = Astro.props;

const STAGES = ['투고 완료', '심사 중', '수정 중', '재투고', '거절'];
const fmtYM = (s?: string) => (s ? s.slice(0, 7).replace('-', '.') : '');
const yearOf = (p: Paper) => (p.sub ? p.sub.slice(0, 4) : '');
---

{
  STAGES.map((stage) => {
    const items = papers.filter((p) => p.st === stage);
    return (
      <div class="kcol" data-stage={stage}>
        <h4>
          {stage} <span class="n num">{items.length}</span>
        </h4>
        {items.map((p) => (
          <div
            class="pcard"
            data-id={p.id}
            data-status={p.st}
            data-stu={p.stu}
            data-tier={p.tier}
            data-year={yearOf(p)}
          >
            <div class="t">{p.t}</div>
            <div class="m">
              <TierBadge tier={p.tier} />
              <StatusBadge variant="stage" stEn={p.stEn} />
              <span class="stu2">주저자 {p.stu}</span>
            </div>
            <div class="m">
              <span class="jr">{p.jr}</span>
            </div>
            <div class="m">
              <span class="stu2 num">{p.sub ? `투고 ${fmtYM(p.sub)}` : '투고 연월 기입 필요'}</span>
            </div>
            {p.note && <div class="warnline">{p.note}</div>}
          </div>
        ))}
        <div class="kempty" hidden={items.length > 0}>
          해당 상태의 논문 없음
        </div>
      </div>
    );
  })
}
