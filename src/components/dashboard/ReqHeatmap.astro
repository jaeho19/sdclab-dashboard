---
// 졸업요건 히트맵 (spec §2 / §3a; mockup L305-314, L641-649).
// 6행(학생) × 7열(요건). 완료=초록 ✓ / 진행=호박 ~ / 미착수=점선 테두리 ·.
// 상태는 저장값(날짜 파생 아님)이라 전부 정적. 셀 hover → 공용 #tip 툴팁(기준·현재).
// 행 머리(rowh)는 학생 상세로 링크.
interface Req {
  c: string;
  std: string;
  now: string;
  st: string;
}
interface Student {
  name: string;
  slug: string;
  deg: string;
  reqs: Req[];
}
interface Props {
  students: Student[];
}
const { students } = Astro.props;
const base = import.meta.env.BASE_URL;

const REQ_COLS = ['이수학점', '어학', '종합시험', '논문자격', '예비심사', '본심사', '최종제출'];
const cellClass = (st: string) => (st === '완료' ? 'done' : st === '진행' ? 'doing' : 'todo');
const mark = (st: string) => (st === '완료' ? '✓' : st === '진행' ? '~' : '·');
---

<div class="card overflow-x-auto p-[18px]">
  <table class="heat">
    <thead>
      <tr>
        <th></th>
        {REQ_COLS.map((c) => <th>{c}</th>)}
      </tr>
    </thead>
    <tbody>
      {
        students.map((s) => (
          <tr>
            <th class="rowh">
              <a href={`${base}students/${s.slug}`} class="block text-inherit no-underline">
                {s.name} <span class="font-medium text-[var(--muted)]">{s.deg}</span>
              </a>
            </th>
            {s.reqs.map((r) => (
              <td>
                <div
                  class:list={['cell', cellClass(r.st)]}
                  data-tip={`${r.c} — 기준: ${r.std}${r.now ? ` · 현재: ${r.now}` : ''}`}
                >
                  {mark(r.st)}
                </div>
              </td>
            ))}
          </tr>
        ))
      }
    </tbody>
  </table>
  <div class="mt-2.5 flex flex-wrap items-center gap-3.5 text-[11.5px] text-[var(--muted)]">
    <span class="inline-flex items-center gap-[5px]">
      <span class="inline-block h-3 w-3 rounded" style="background:color-mix(in srgb, var(--ok) 16%, transparent)"></span>완료 ✓
    </span>
    <span class="inline-flex items-center gap-[5px]">
      <span class="inline-block h-3 w-3 rounded" style="background:var(--warn-bg)"></span>진행 ~
    </span>
    <span class="inline-flex items-center gap-[5px]">
      <span class="inline-block h-3 w-3 rounded" style="border:1.5px dashed var(--line)"></span>미착수
    </span>
    <span class="ml-auto">셀에 마우스를 올리면 규정 기준·현재 상태가 표시됩니다</span>
  </div>
</div>
