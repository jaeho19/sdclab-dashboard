---
// 연구 흐름도 — 단계 레일(거시) + 클릭 시 펼쳐지는 세부 아코디언.
// 데이터는 각 과제 .md 의 frontmatter `flow:` 에서 옵니다(회의록·결정사항 따라 갱신).
interface Step { text: string; status: string; }
interface Stage { label: string; status: string; summary?: string; period?: string; steps: Step[]; }
interface Flow { note?: string; stages: Stage[]; }
interface Props { flow: Flow; color: string; }
const { flow, color } = Astro.props;
const stages = flow.stages ?? [];

// 상태별 스타일 토큰 (4색: 완료·진행·다음주·예정)
const S: Record<string, { dot: string; chip: string; badge: string; label: string; step: string }> = {
  '완료':   { dot: 'bg-emerald-500',            chip: 'border-emerald-300 bg-emerald-50',                 badge: 'bg-emerald-100 text-emerald-700',  label: '완료',     step: 'text-emerald-600' },
  '진행':   { dot: 'bg-blue-500 ring-4 ring-blue-100', chip: 'border-blue-400 bg-blue-50 shadow-sm',     badge: 'bg-blue-100 text-blue-700',        label: '진행 중',  step: 'text-blue-600' },
  '다음주': { dot: 'bg-amber-500',              chip: 'border-amber-400 bg-amber-50',                     badge: 'bg-amber-100 text-amber-800',      label: '다음 주',  step: 'text-amber-600' },
  '예정':   { dot: 'border-2 border-slate-300 bg-white', chip: 'border-dashed border-slate-300 bg-white',  badge: 'bg-slate-100 text-slate-500',      label: '예정',     step: 'text-slate-300' },
};
const tok = (s: string) => S[s] ?? S['예정'];
// 진행 중 단계가 있으면 그 단계, 없으면 다음주, 없으면 첫 미완료 단계를 기본으로 펼침
const defaultOpen = (() => {
  const order = ['진행', '다음주', '예정'];
  for (const st of order) { const i = stages.findIndex((s) => s.status === st); if (i >= 0) return i; }
  return 0;
})();
---
<section class="mt-7" id="flow">
  <div class="mb-3 flex items-end justify-between">
    <h2 class="text-sm font-bold uppercase tracking-wide text-slate-500">연구 흐름도</h2>
    <span class="text-[0.72rem] text-[var(--muted)]">단계를 누르면 세부 내용이 펼쳐집니다 ↓</span>
  </div>

  <div class="rounded-2xl border border-[var(--line)] bg-white p-5" style={`border-top:4px solid ${color}`}>
    <!-- 범례 -->
    <div class="mb-4 flex flex-wrap items-center gap-x-4 gap-y-1.5 text-[0.72rem] text-[var(--muted)]">
      <span class="font-semibold text-slate-500">색상 구분:</span>
      <span class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-emerald-500"></span>완료</span>
      <span class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-blue-500 ring-2 ring-blue-100"></span>진행 중 <span class="text-slate-400">(현재)</span></span>
      <span class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-amber-500"></span>다음 주 업무</span>
      <span class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full border-2 border-slate-300 bg-white"></span>예정 <span class="text-slate-400">(향후 계획)</span></span>
    </div>

    <!-- 거시 흐름 레일 (한눈에 보기) -->
    <div class="-mx-1 flex items-stretch gap-1 overflow-x-auto no-scrollbar px-1 pb-1" role="list" aria-label="연구 단계 흐름">
      {stages.map((s, i) => (
        <div class="flex items-stretch" role="listitem">
          <button
            type="button"
            data-flow-node={i}
            class={`flow-node group flex w-40 shrink-0 flex-col rounded-xl border px-3 py-2.5 text-left transition hover:shadow-md ${tok(s.status).chip}`}
            aria-expanded={i === defaultOpen ? 'true' : 'false'}
            aria-controls={`flow-stage-${i}`}
          >
            <div class="flex items-center gap-2">
              <span class={`grid h-5 w-5 shrink-0 place-items-center rounded-full text-[0.65rem] font-bold text-white ${s.status === '예정' ? '!text-slate-400' : ''} ${tok(s.status).dot}`}>{i + 1}</span>
              <span class={`rounded px-1.5 py-0.5 text-[0.6rem] font-bold ${tok(s.status).badge}`}>{tok(s.status).label}</span>
            </div>
            <span class="mt-1.5 text-[0.82rem] font-bold leading-snug text-slate-800">{s.label}</span>
            {s.summary && <span class="mt-0.5 text-[0.7rem] leading-snug text-[var(--muted)] line-clamp-2">{s.summary}</span>}
            {s.period && <span class="mt-1 text-[0.62rem] font-medium text-slate-400">{s.period}</span>}
          </button>
          {i < stages.length - 1 && (
            <div class="flex shrink-0 items-center px-0.5 text-slate-300" aria-hidden="true">→</div>
          )}
        </div>
      ))}
    </div>

    <!-- 세부 단계 (토글 아코디언) -->
    <div class="mt-4 space-y-2">
      {stages.map((s, i) => (
        <details id={`flow-stage-${i}`} data-flow-detail={i} open={i === defaultOpen} class="group rounded-xl border border-[var(--line)] bg-slate-50/60">
          <summary class="flex cursor-pointer list-none items-center gap-2.5 px-4 py-3">
            <span class={`grid h-6 w-6 shrink-0 place-items-center rounded-full text-[0.7rem] font-bold text-white ${s.status === '예정' ? '!text-slate-400' : ''} ${tok(s.status).dot}`}>{i + 1}</span>
            <span class="text-[0.7rem] font-semibold text-slate-400">{i + 1}단계</span>
            <span class="min-w-0 flex-1 truncate text-sm font-bold text-slate-800">{s.label}</span>
            <span class={`shrink-0 rounded px-2 py-0.5 text-[0.62rem] font-bold ${tok(s.status).badge}`}>{tok(s.status).label}</span>
            <span class="shrink-0 text-slate-300 transition group-open:rotate-180" aria-hidden="true">▾</span>
          </summary>
          <div class="border-t border-[var(--line)] px-4 py-3">
            {s.summary && <p class="mb-2.5 text-sm leading-relaxed text-slate-600">{s.summary}</p>}
            {s.steps.length > 0 ? (
              <ul class="space-y-1.5">
                {s.steps.map((st) => (
                  <li class="flex items-start gap-2 text-sm leading-relaxed">
                    <span class={`mt-1.5 h-2 w-2 shrink-0 rounded-full ${tok(st.status).dot}`}></span>
                    <span class={`flex-1 ${st.status === '완료' ? 'text-slate-500' : 'text-slate-700'}`}>{st.text}</span>
                    <span class={`shrink-0 text-[0.6rem] font-bold ${tok(st.status).step}`}>{st.status === '예정' ? '' : tok(st.status).label}</span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="text-sm text-[var(--muted)]">세부 항목이 아직 정리되지 않았습니다.</p>
            )}
            {s.period && <p class="mt-2.5 text-[0.7rem] font-medium text-slate-400">기간: {s.period}</p>}
          </div>
        </details>
      ))}
    </div>

    <!-- 하단 설명 -->
    <div class="mt-4 rounded-xl bg-slate-50 px-4 py-3 text-xs leading-relaxed text-[var(--muted)]">
      {flow.note && <p class="mb-1.5 text-slate-600">{flow.note}</p>}
      <p>※ 이 흐름도는 <strong class="font-semibold text-slate-500">거시 단계(위 레일)</strong>에서 시작해 각 단계를 누르면 <strong class="font-semibold text-slate-500">세부 항목</strong>이 펼쳐집니다. 색상은 <span class="font-semibold text-emerald-600">완료</span> · <span class="font-semibold text-blue-600">진행 중(현재)</span> · <span class="font-semibold text-amber-600">다음 주 업무</span> · <span class="font-semibold text-slate-400">예정(향후)</span> 을 뜻하며, 회의록·결정사항에 따라 frontmatter <code class="rounded bg-slate-100 px-1">flow:</code> 를 수정하면 갱신됩니다.</p>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const nodes = document.querySelectorAll('[data-flow-node]');
    const open = (i, scroll) => {
      const details = document.querySelectorAll('[data-flow-detail]');
      details.forEach((d) => { d.open = String(d.getAttribute('data-flow-detail')) === String(i); });
      nodes.forEach((n) => {
        const on = String(n.getAttribute('data-flow-node')) === String(i);
        n.setAttribute('aria-expanded', on ? 'true' : 'false');
        n.classList.toggle('ring-2', on);
        n.classList.toggle('ring-offset-1', on);
      });
      if (scroll) {
        const t = document.getElementById('flow-stage-' + i);
        if (t) t.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    };
    nodes.forEach((n) => n.addEventListener('click', () => open(n.getAttribute('data-flow-node'), true)));
    // 초기: 기본 펼친 단계의 노드를 강조
    const opened = document.querySelector('[data-flow-detail][open]');
    if (opened) open(opened.getAttribute('data-flow-detail'), false);
  })();
</script>
