---
interface Props { status: string; }
const { status } = Astro.props;
const map: Record<string, string> = {
  '초기': 'bg-sky-100 text-sky-700 ring-sky-200',
  '진행중': 'bg-emerald-100 text-emerald-700 ring-emerald-200',
  '마무리': 'bg-amber-100 text-amber-700 ring-amber-200',
  '완료': 'bg-slate-200 text-slate-600 ring-slate-300',
};
const cls = map[status] ?? 'bg-slate-100 text-slate-600 ring-slate-200';
---
<span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold ring-1 ring-inset ${cls}`}>{status}</span>
