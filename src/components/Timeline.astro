---
import { parseDate, parseDateEnd, pct, today, fmtDate, fmtMD, fmtRange } from '../lib/dates';

interface EventItem { date: string; label: string; type: string; status: string; }
interface YearPhase { label: string; start: string; end: string; }
interface ProjectRow {
  slug: string; title: string; color: string;
  period_start: string; period_end: string; events: EventItem[];
  years?: YearPhase[];
}
interface Props { projects: ProjectRow[]; from?: string; mode?: 'overview' | 'detail'; }
const { projects, from, mode = 'detail' } = Astro.props;
const base = import.meta.env.BASE_URL;
const detail = mode === 'detail';

// ── 구간 계산 ───────────────────────────────
let minD = Infinity, maxD = -Infinity;
for (const p of projects) {
  minD = Math.min(minD, parseDate(p.period_start).getTime());
  maxD = Math.max(maxD, parseDateEnd(p.period_end).getTime());
  for (const e of p.events) { const t = parseDate(e.date).getTime(); minD = Math.min(minD, t); maxD = Math.max(maxD, t); }
  for (const y of p.years ?? []) { minD = Math.min(minD, parseDate(y.start).getTime()); maxD = Math.max(maxD, parseDateEnd(y.end).getTime()); }
}
let min = new Date(minD), max = new Date(maxD);
if (from) min = parseDate(from);
min = new Date(min.getFullYear(), min.getMonth(), 1);
max = new Date(max.getFullYear(), max.getMonth() + 1, 0);

const months: Date[] = [];
let cur = new Date(min);
while (cur <= max) { months.push(new Date(cur)); cur = new Date(cur.getFullYear(), cur.getMonth() + 1, 1); }

const PX = detail ? 130 : 42;            // detail: 확대(월 130px), overview: 축소(월 42px)
const trackW = months.length * PX;
const LABEL_W = 150;
const ROW = detail ? 76 : 50;
const leftPx = (d: Date) => (pct(d, min, max) / 100) * trackW;
const todayD = today();
const todayLeft = leftPx(todayD);
const todayIn = todayD >= min && todayD <= max;
const inRange = (d: Date) => d >= min && d <= max;

const dotFill: Record<string, string> = { '완료': '#94a3b8', '진행': '#f59e0b', '예정': '#ffffff' };
const yearRows = projects.filter((p) => p.years && p.years.length > 0);

// 행별 이벤트 + 라벨 솎아내기(겹침 방지)
const rowItems = projects.map((p) => {
  const evs = p.events.filter((e) => inRange(parseDate(e.date))).sort((a, b) => parseDate(a.date).getTime() - parseDate(b.date).getTime());
  let lastLabelX = -Infinity, li = 0;
  return evs.map((e) => {
    const x = leftPx(parseDate(e.date));
    let showLabel = detail && x - lastLabelX >= 30;
    let above = false;
    if (showLabel) { above = li % 2 === 0; li++; lastLabelX = x; }
    return { e, x, showLabel, above };
  });
});
---
<div class="overflow-x-auto no-scrollbar rounded-2xl border border-[var(--line)] bg-white" data-today-x={detail && todayIn ? Math.round(LABEL_W + todayLeft) : undefined}>
  <div style={`min-width:${LABEL_W + trackW}px`}>

    <!-- 월 눈금 헤더 -->
    <div class="flex items-end border-b border-[var(--line)]">
      <div class="sticky left-0 z-30 shrink-0 bg-white" style={`width:${LABEL_W}px;height:40px`}></div>
      <div class="relative" style={`width:${trackW}px;height:40px`}>
        {months.map((m) => {
          const isYear = m.getMonth() === 0;
          return (
            <div class="absolute bottom-0" style={`left:${leftPx(m)}px`}>
              <div class={`w-px ${isYear ? 'h-4 bg-slate-300' : 'h-2 bg-slate-200'}`}></div>
              <span class="absolute bottom-2.5 left-0.5 text-[0.58rem] text-slate-400">{m.getMonth() + 1}</span>
              {isYear && <span class="absolute bottom-6 left-0.5 whitespace-nowrap text-[0.72rem] font-bold text-slate-600">{m.getFullYear()}</span>}
            </div>
          );
        })}
        {min.getMonth() !== 0 && (
          <span class="absolute bottom-6 left-1 whitespace-nowrap text-[0.72rem] font-bold text-slate-600">{min.getFullYear()}</span>
        )}
        {todayIn && (
          <span class="absolute -top-0.5 z-10 -translate-x-1/2 rounded bg-rose-500 px-1 py-0.5 text-[0.6rem] font-bold text-white" style={`left:${todayLeft}px`}>오늘</span>
        )}
      </div>
    </div>

    <!-- 과제 행 -->
    {projects.map((p, ri) => {
      const x0 = leftPx(parseDate(p.period_start));
      const x1 = leftPx(parseDateEnd(p.period_end));
      return (
        <div class="flex items-stretch border-t border-[var(--line)]">
          <a href={`${base}projects/${p.slug}`} class="sticky left-0 z-30 flex shrink-0 items-center gap-2 bg-white px-3 hover:bg-slate-50" style={`width:${LABEL_W}px`}>
            <span class="h-2.5 w-2.5 shrink-0 rounded-full" style={`background:${p.color}`}></span>
            <span class="truncate text-[0.8rem] font-semibold text-slate-700">{p.title}</span>
          </a>
          <div class="relative" style={`width:${trackW}px;height:${ROW}px`}>
            {months.map((m) => (
              <div class={`absolute top-0 bottom-0 w-px ${m.getMonth() === 0 ? 'bg-slate-100' : 'bg-slate-50'}`} style={`left:${leftPx(m)}px`}></div>
            ))}
            {todayIn && <div class="absolute top-0 bottom-0 z-10 w-px bg-rose-400/70" style={`left:${todayLeft}px`}></div>}

            {p.years && p.years.length > 0 ? (
              p.years.map((yr) => {
                const a = leftPx(parseDate(yr.start));
                const b = leftPx(parseDateEnd(yr.end));
                const w = Math.max(6, b - a);
                return (
                  <Fragment>
                    <div class="absolute top-1/2 -translate-y-1/2 rounded-md" style={`left:${a}px;width:${w}px;height:16px;background:${p.color};opacity:.18`}></div>
                    {w > 44 && (
                      <span class="absolute top-1/2 z-[5] -translate-x-1/2 -translate-y-1/2 whitespace-nowrap text-[0.6rem] font-bold" style={`left:${a + w / 2}px;color:${p.color}`}>{yr.label}</span>
                    )}
                  </Fragment>
                );
              })
            ) : (
              <div class="absolute top-1/2 -translate-y-1/2 rounded-full" style={`left:${x0}px;width:${Math.max(6, x1 - x0)}px;height:14px;background:${p.color};opacity:.22`}></div>
            )}

            {rowItems[ri].map(({ e, x, showLabel, above }) => {
              const edge = e.type === '마감' || e.type === '제출';
              return (
                <Fragment>
                  <div
                    class="absolute z-20 h-3 w-3 -translate-x-1/2 -translate-y-1/2 rounded-full border-2"
                    style={`left:${x}px;top:50%;background:${dotFill[e.status] ?? '#fff'};border-color:${edge ? '#e11d48' : p.color}`}
                    title={`${fmtDate(e.date)} · ${e.label}`}
                  ></div>
                  {showLabel && (
                    <span
                      class="absolute z-20 -translate-x-1/2 whitespace-nowrap text-[0.58rem] font-semibold"
                      style={`left:${x}px;top:${above ? 'calc(50% - 22px)' : 'calc(50% + 12px)'};color:${edge ? '#e11d48' : '#64748b'}`}
                    >{fmtMD(e.date)}</span>
                  )}
                </Fragment>
              );
            })}
          </div>
        </div>
      );
    })}
  </div>
</div>

<!-- 범례 -->
<div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1.5 text-[0.72rem] text-[var(--muted)]">
  <span class="flex items-center gap-1.5"><span class="h-3 w-3 rounded-full border-2 border-slate-400 bg-slate-400"></span>완료</span>
  <span class="flex items-center gap-1.5"><span class="h-3 w-3 rounded-full border-2 border-slate-400 bg-amber-400"></span>진행</span>
  <span class="flex items-center gap-1.5"><span class="h-3 w-3 rounded-full border-2 border-slate-400 bg-white"></span>예정</span>
  <span class="flex items-center gap-1.5"><span class="h-3 w-3 rounded-full border-2 border-rose-500 bg-white"></span>제출/마감</span>
  <span class="flex items-center gap-1.5"><span class="inline-block h-3 w-px bg-rose-400"></span>오늘</span>
  {detail && <span class="text-slate-400">· 좌우로 스크롤하면 전체 일정을 볼 수 있습니다 (점 위에 마우스를 올리면 상세)</span>}
</div>

<!-- 연차 구분 (하단 별도 표기) -->
{yearRows.length > 0 && (
  <div class="mt-3 rounded-xl bg-slate-50 px-4 py-3">
    <p class="mb-1.5 text-[0.7rem] font-semibold uppercase tracking-wide text-slate-400">연차 구분 (R&D)</p>
    <div class="space-y-1.5">
      {yearRows.map((p) => (
        <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-[0.74rem]">
          <span class="flex items-center gap-1 font-semibold text-slate-700"><span class="h-2 w-2 rounded-full" style={`background:${p.color}`}></span>{p.title}</span>
          {p.years!.map((y) => (
            <span class="rounded-md border border-[var(--line)] bg-white px-2 py-0.5 text-slate-600">{y.label} · {fmtRange(y.start, y.end)}</span>
          ))}
        </div>
      ))}
    </div>
  </div>
)}

{detail && (
  <script is:inline>
    for (const el of document.querySelectorAll('[data-today-x]')) {
      const x = parseFloat(el.getAttribute('data-today-x'));
      if (!Number.isNaN(x)) el.scrollLeft = Math.max(0, x - el.clientWidth * 0.38);
    }
  </script>
)}
