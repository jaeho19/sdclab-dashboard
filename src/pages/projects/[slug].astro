---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import Timeline from '../../components/Timeline.astro';
import { fmtRange, fmtDate, dday, fmtDday, parseDate, today } from '../../lib/dates';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const p = entry.data;
const { Content } = await render(entry);
const base = import.meta.env.BASE_URL;

const row = {
  slug: entry.id, title: p.title, color: p.color,
  period_start: p.period_start, period_end: p.period_end, events: p.events,
};

const t = today().getTime();
const sortedEvents = [...p.events].sort((a, b) => parseDate(a.date).getTime() - parseDate(b.date).getTime());
const next = sortedEvents.find((e) => e.status !== '완료' && parseDate(e.date).getTime() >= t);

const typeBadge: Record<string, string> = {
  '마감': 'bg-rose-100 text-rose-700', '제출': 'bg-rose-100 text-rose-700',
  '보고': 'bg-amber-100 text-amber-700', '회의': 'bg-sky-100 text-sky-700',
  '마일스톤': 'bg-slate-100 text-slate-600',
};
const stBadge: Record<string, string> = {
  '완료': 'bg-slate-200 text-slate-600', '진행': 'bg-amber-100 text-amber-700', '예정': 'bg-white text-slate-500 ring-1 ring-slate-200',
};
---
<Base title={`${p.title} · SDC Lab 대시보드`} description={p.summary ?? p.title}>
  <a href={base} class="mb-4 inline-flex items-center gap-1 text-sm text-[var(--muted)] hover:text-slate-900">← 전체 대시보드</a>

  <!-- 헤더 -->
  <div class="rounded-2xl border border-[var(--line)] bg-white p-6">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div class="min-w-0">
        <div class="flex items-center gap-2.5">
          <span class="h-3 w-3 shrink-0 rounded-full" style={`background:${p.color}`}></span>
          <h1 class="text-xl font-extrabold tracking-tight text-slate-900 sm:text-2xl">{p.title}</h1>
        </div>
        {p.title_en && <p class="mt-1 text-sm text-[var(--muted)]">{p.title_en}</p>}
      </div>
      <StatusBadge status={p.status} />
    </div>

    <dl class="mt-5 grid grid-cols-2 gap-x-6 gap-y-3 text-sm sm:grid-cols-4">
      <div><dt class="text-xs text-[var(--muted)]">발주처</dt><dd class="font-semibold text-slate-700">{p.agency}</dd></div>
      <div><dt class="text-xs text-[var(--muted)]">연구기간</dt><dd class="font-semibold text-slate-700">{fmtRange(p.period_start, p.period_end)}</dd></div>
      {p.budget && <div><dt class="text-xs text-[var(--muted)]">예산</dt><dd class="font-semibold text-slate-700">{p.budget}</dd></div>}
      {p.pi && <div><dt class="text-xs text-[var(--muted)]">연구책임자</dt><dd class="font-semibold text-slate-700">{p.pi}</dd></div>}
    </dl>

    <!-- 진척바 -->
    <div class="mt-5">
      <div class="mb-1 flex items-center justify-between text-xs">
        <span class="font-medium text-slate-500">진척도</span>
        <span class="font-bold" style={`color:${p.color}`}>{p.progress}%</span>
      </div>
      <div class="h-2.5 w-full overflow-hidden rounded-full bg-slate-100">
        <div class="h-full rounded-full" style={`width:${p.progress}%;background:${p.color}`}></div>
      </div>
    </div>

    {next && (
      <div class="mt-4 inline-flex items-center gap-2 rounded-xl bg-slate-50 px-3 py-2 text-sm">
        <span class="text-xs font-semibold uppercase text-slate-400">다음</span>
        <span class="font-medium text-slate-700">{next.label}</span>
        <span class="text-xs text-[var(--muted)]">{fmtDate(next.date)}</span>
        <span class="rounded-md bg-rose-100 px-2 py-0.5 text-xs font-bold text-rose-700">{fmtDday(dday(next.date))}</span>
      </div>
    )}

    {p.team.length > 0 && (
      <div class="mt-4">
        <p class="mb-1.5 text-xs text-[var(--muted)]">참여진</p>
        <div class="flex flex-wrap gap-1.5">
          {p.team.map((m) => <span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs text-slate-600">{m}</span>)}
        </div>
      </div>
    )}

    {p.keywords.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {p.keywords.map((k) => <span class="rounded-md bg-indigo-50 px-2 py-0.5 text-xs text-indigo-600">#{k}</span>)}
      </div>
    )}
  </div>

  <!-- 과제 타임라인 -->
  <section class="mt-7">
    <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-500">과제 타임라인</h2>
    <Timeline projects={[row]} />
  </section>

  <!-- 본문: 회의 / 진행상황 / 할 일 -->
  <article class="prose mt-8 max-w-none rounded-2xl border border-[var(--line)] bg-white p-6">
    <Content />
  </article>

  <!-- 일정 표 -->
  {sortedEvents.length > 0 && (
    <section class="mt-7">
      <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-500">전체 일정표</h2>
      <div class="overflow-hidden rounded-2xl border border-[var(--line)] bg-white">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[var(--line)] bg-slate-50 text-left text-xs text-slate-500">
              <th class="px-4 py-2.5 font-semibold">날짜</th>
              <th class="px-4 py-2.5 font-semibold">항목</th>
              <th class="px-4 py-2.5 font-semibold">유형</th>
              <th class="px-4 py-2.5 font-semibold">상태</th>
            </tr>
          </thead>
          <tbody>
            {sortedEvents.map((e) => (
              <tr class="border-b border-[var(--line)] last:border-0">
                <td class="whitespace-nowrap px-4 py-2.5 font-medium text-slate-600">{fmtDate(e.date)}</td>
                <td class="px-4 py-2.5 text-slate-700">{e.label}</td>
                <td class="px-4 py-2.5"><span class={`rounded-md px-2 py-0.5 text-xs font-medium ${typeBadge[e.type] ?? 'bg-slate-100 text-slate-600'}`}>{e.type}</span></td>
                <td class="px-4 py-2.5"><span class={`rounded-md px-2 py-0.5 text-xs font-medium ${stBadge[e.status] ?? ''}`}>{e.status}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}
</Base>
