---
import Base from '../../layouts/Base.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import Timeline from '../../components/Timeline.astro';
import FlowDiagram from '../../components/FlowDiagram.astro';
import { getProjects } from '../../lib/content';
import { fmtRange, fmtDate, dday, fmtDday, parseDate, today } from '../../lib/dates';

export async function getStaticPaths() {
  const entries = await getProjects();
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const p = entry.data;
const base = import.meta.env.BASE_URL;

const row = {
  slug: entry.id, title: p.title, color: p.color,
  period_start: p.period_start, period_end: p.period_end, events: p.events, years: p.years,
};

const t = today().getTime();

// (a) 최근 회의
const meetings = [...(p.meetings ?? [])].sort((a, b) => parseDate(b.date).getTime() - parseDate(a.date).getTime());
const latest = meetings[0];
const daysAgo = latest ? Math.round((t - parseDate(latest.date).getTime()) / 86400000) : null;

// (d) 향후 주요 일정
const upcoming = [...p.events]
  .filter((e) => e.status !== '완료' && parseDate(e.date).getTime() >= t)
  .sort((a, b) => parseDate(a.date).getTime() - parseDate(b.date).getTime());

const typeColor: Record<string, string> = {
  '마감': 'text-rose-600', '제출': 'text-rose-600', '보고': 'text-amber-600',
  '회의': 'text-sky-600', '마일스톤': 'text-slate-500',
};
---
<Base title={`${p.title} · SDC Lab 대시보드`} description={p.summary ?? p.title}>
  <a href={base} class="mb-4 inline-flex items-center gap-1 text-sm text-[var(--muted)] hover:text-slate-900">← 전체 대시보드</a>

  <!-- 과제 개요 -->
  <div class="rounded-2xl border border-[var(--line)] bg-white p-6">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div class="min-w-0">
        <div class="flex items-center gap-2.5">
          <span class="h-3 w-3 shrink-0 rounded-full" style={`background:${p.color}`}></span>
          <h1 class="text-xl font-extrabold tracking-tight text-slate-900 sm:text-2xl">{p.title}</h1>
        </div>
        {p.title_en && <p class="mt-1 text-sm text-[var(--muted)]">{p.title_en}</p>}
      </div>
      <StatusBadge status={p.status} />
    </div>

    <dl class="mt-5 grid grid-cols-2 gap-x-6 gap-y-3 text-sm sm:grid-cols-4">
      <div><dt class="text-xs text-[var(--muted)]">발주처</dt><dd class="font-semibold text-slate-700">{p.agency}</dd></div>
      <div><dt class="text-xs text-[var(--muted)]">연구기간</dt><dd class="font-semibold text-slate-700">{fmtRange(p.period_start, p.period_end)}</dd></div>
      {p.budget && <div><dt class="text-xs text-[var(--muted)]">예산</dt><dd class="font-semibold text-slate-700">{p.budget}</dd></div>}
      {p.pi && <div><dt class="text-xs text-[var(--muted)]">연구책임자</dt><dd class="font-semibold text-slate-700">{p.pi}</dd></div>}
    </dl>

    {p.link && (
      <a href={p.link} target="_blank" rel="noopener noreferrer"
         class="mt-4 inline-flex items-center gap-1.5 rounded-xl px-3.5 py-2 text-sm font-semibold text-white transition hover:opacity-90"
         style={`background:${p.color}`}>
        {p.link_label ?? '관련 사이트'}
        <span aria-hidden="true">↗</span>
      </a>
    )}

    <div class="mt-5">
      <div class="mb-1 flex items-center justify-between text-xs">
        <span class="font-medium text-slate-500">진척도</span>
        <span class="font-bold" style={`color:${p.color}`}>{p.progress}%</span>
      </div>
      <div class="h-2.5 w-full overflow-hidden rounded-full bg-slate-100">
        <div class="h-full rounded-full" style={`width:${p.progress}%;background:${p.color}`}></div>
      </div>
    </div>

    {p.team.length > 0 && (
      <div class="mt-4">
        <p class="mb-1.5 text-xs text-[var(--muted)]">참여진</p>
        <div class="flex flex-wrap gap-1.5">
          {p.team.map((m) => <span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs text-slate-600">{m}</span>)}
        </div>
      </div>
    )}

    {p.keywords.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {p.keywords.map((k) => <span class="rounded-md bg-indigo-50 px-2 py-0.5 text-xs text-indigo-600">#{k}</span>)}
      </div>
    )}
  </div>

  <!-- 강조 콜아웃 (예: MVP 데이터 목록) -->
  {p.highlights && p.highlights.length > 0 && (
    <section class="mt-6 space-y-3">
      {p.highlights.map((h) => (
        <div class="rounded-2xl border border-[var(--line)] bg-white p-5" style={`border-left:5px solid ${p.color}`}>
          <p class="text-sm font-bold text-slate-800">{h.label}</p>
          <ul class="mt-2.5 space-y-1.5">
            {h.items.map((it) => (
              <li class="flex items-start gap-2 text-sm leading-relaxed text-slate-700">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style={`background:${p.color}`}></span>
                <span>{it}</span>
              </li>
            ))}
          </ul>
          {h.note && <p class="mt-2.5 rounded-lg bg-slate-50 px-3 py-2 text-xs leading-relaxed text-[var(--muted)]">{h.note}</p>}
        </div>
      ))}
    </section>
  )}

  <!-- 연구 흐름도 -->
  {p.flow && p.flow.stages && p.flow.stages.length > 0 && (
    <FlowDiagram flow={p.flow} color={p.color} progress={p.progress} />
  )}

  <!-- 타임라인 -->
  <section class="mt-7">
    <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-500">타임라인</h2>
    <Timeline projects={[row]} />
  </section>

  <div class="mt-7 grid grid-cols-1 gap-6 lg:grid-cols-2">
    <!-- (a) 최근 회의 -->
    <section class="lg:col-span-2">
      <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-500">최근 회의</h2>
      {latest ? (
        <div class="rounded-2xl border-l-4 bg-white p-5 shadow-sm" style={`border-color:${p.color}`}>
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-sm font-bold text-slate-800">{latest.title}</span>
            <span class="text-xs font-medium text-[var(--muted)]">{fmtDate(latest.date)}{daysAgo !== null && daysAgo >= 0 ? ` · ${daysAgo === 0 ? '오늘' : daysAgo + '일 전'}` : ''}</span>
          </div>
          {latest.summary && <p class="mt-2 text-sm leading-relaxed text-slate-600">{latest.summary}</p>}
          <div class="mt-3 grid grid-cols-1 gap-x-6 gap-y-4 sm:grid-cols-2">
            {latest.decisions.length > 0 && (
              <div>
                <p class="mb-2 text-xs font-bold text-emerald-700">✓ 이번 회의 결정 사항</p>
                <ul class="space-y-1.5">
                  {latest.decisions.map((d: string) => (
                    <li class="flex items-start gap-2 text-sm leading-relaxed text-slate-700"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-400"></span><span>{d}</span></li>
                  ))}
                </ul>
              </div>
            )}
            {latest.next.length > 0 && (
              <div>
                <p class="mb-2 text-xs font-bold text-indigo-700">▶ 다음 회의·진행 업무</p>
                <ul class="space-y-1.5">
                  {latest.next.map((n: string) => (
                    <li class="flex items-start gap-2 text-sm leading-relaxed text-slate-700"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-indigo-400"></span><span>{n}</span></li>
                  ))}
                </ul>
              </div>
            )}
          </div>
          {meetings.length > 1 && (
            <a href={`${base}projects/${entry.id}/archive`} class="mt-4 inline-block text-xs font-medium text-slate-400 hover:text-slate-700">이전 회의 {meetings.length - 1}건 전체 보기 →</a>
          )}
        </div>
      ) : (
        <p class="text-sm text-[var(--muted)]">기록된 회의가 없습니다.</p>
      )}
    </section>

    <!-- (b) 향후 주요 과제 -->
    <section>
      <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-500">향후 주요 과제</h2>
      <div class="rounded-2xl border border-[var(--line)] bg-white p-5">
        {p.next_tasks && p.next_tasks.length > 0 ? (
          <ul class="space-y-2.5">
            {p.next_tasks.map((nt) => {
              const d = nt.due ? dday(nt.due) : null;
              return (
                <li class="flex items-start gap-2.5">
                  <span class={`mt-1 h-1.5 w-1.5 shrink-0 rounded-full ${nt.done ? 'bg-slate-300' : ''}`} style={nt.done ? '' : `background:${p.color}`}></span>
                  <span class="min-w-0 flex-1">
                    <span class={`text-sm ${nt.done ? 'text-slate-400 line-through' : 'font-medium text-slate-700'}`}>{nt.task}</span>
                    {nt.due && <span class="ml-2 whitespace-nowrap text-xs text-[var(--muted)]">{fmtDate(nt.due)}{d !== null && d >= 0 ? ` (${fmtDday(d)})` : ''}</span>}
                  </span>
                </li>
              );
            })}
          </ul>
        ) : (
          <p class="text-sm text-[var(--muted)]">등록된 과제가 없습니다.</p>
        )}
      </div>
    </section>

    <!-- (c) 현재 진행 단계 & 팀 목적 -->
    <section>
      <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-500">현재 진행 단계 · 팀 목적</h2>
      <div class="space-y-3">
        <div class="rounded-2xl border border-[var(--line)] bg-white p-5">
          <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-slate-400">현재 단계</p>
          <p class="text-sm leading-relaxed text-slate-700">{p.current_stage ?? '—'}</p>
        </div>
        {p.purpose && (
          <div class="rounded-2xl bg-slate-900 p-5 text-white">
            <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-slate-400">우리 팀의 목적</p>
            <p class="text-sm leading-relaxed">{p.purpose}</p>
          </div>
        )}
      </div>
    </section>

    <!-- (d) 향후 주요 일정 -->
    <section class="lg:col-span-2">
      <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-500">향후 주요 일정 (D-day)</h2>
      <div class="rounded-2xl border border-[var(--line)] bg-white p-2">
        {upcoming.length > 0 ? (
          <ul class="divide-y divide-[var(--line)]">
            {upcoming.map((e) => {
              const d = dday(e.date);
              return (
                <li class="flex items-center gap-3 px-3 py-2.5">
                  <span class="w-16 shrink-0 text-right text-xs font-medium text-[var(--muted)]">{fmtDate(e.date)}</span>
                  <span class="h-2 w-2 shrink-0 rounded-full" style={`background:${p.color}`}></span>
                  <span class="min-w-0 flex-1 text-sm font-medium text-slate-700">{e.label}
                    <span class={`ml-2 text-xs ${typeColor[e.type] ?? 'text-slate-500'}`}>{e.type}</span>
                  </span>
                  <span class={`shrink-0 rounded-lg px-2 py-1 text-xs font-bold ${d <= 14 ? 'bg-rose-100 text-rose-700' : 'bg-slate-100 text-slate-600'}`}>{fmtDday(d)}</span>
                </li>
              );
            })}
          </ul>
        ) : (
          <p class="px-3 py-4 text-sm text-[var(--muted)]">예정된 일정이 없습니다.</p>
        )}
      </div>
    </section>
  </div>

  <!-- 아카이브 -->
  <div class="mt-8 flex items-center justify-between rounded-2xl border border-dashed border-[var(--line)] bg-white px-5 py-4">
    <div>
      <p class="text-sm font-semibold text-slate-700">회의 히스토리 · 전체 일정표</p>
      <p class="text-xs text-[var(--muted)]">지금까지의 회의 기록과 전체 일정은 아카이브에서 봅니다.</p>
    </div>
    <a href={`${base}projects/${entry.id}/archive`} class="shrink-0 rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">아카이브 →</a>
  </div>
</Base>
