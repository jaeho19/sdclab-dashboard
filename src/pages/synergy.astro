---
import Base from '../layouts/Base.astro';
import { getProjects, getSynergy } from '../lib/content';

const projectEntries = await getProjects();
const meta = (slug: string) => projectEntries.find((p) => p.id === slug)?.data;

const syn = await getSynergy();
const data = syn?.data;
const links = (data?.links ?? []) as any[];
const base = import.meta.env.BASE_URL;

// 연계 맵 노드 좌표 (600 x 376 박스)
const NW = 240, NH = 96;
const posMap: Record<string, { x: number; y: number }> = {
  'forest-equity': { x: 20, y: 24 },
  'nrf-early-career': { x: 340, y: 24 },
  'gyeonggi-participatory-data': { x: 20, y: 256 },
  'nrf-ai-participation': { x: 340, y: 256 },
};
const center = (slug: string) => {
  const p = posMap[slug] ?? { x: 20, y: 24 };
  return { cx: p.x + NW / 2, cy: p.y + NH / 2 };
};
const nodeSlugs = Object.keys(posMap).filter((s) => meta(s));
const edges = links
  .filter((l) => posMap[l.a] && posMap[l.b])
  .map((l) => {
    const A = center(l.a), B = center(l.b);
    return { ...l, A, B, mx: (A.cx + B.cx) / 2, my: (A.cy + B.cy) / 2 };
  });

const sortedLinks = [...links].sort((a, b) => (a.strength === '강' ? 0 : 1) - (b.strength === '강' ? 0 : 1));
const short = (slug: string) => meta(slug)?.title ?? slug;
const color = (slug: string) => meta(slug)?.color ?? '#64748b';
---
<Base title="연구 연계 · 성과 공유 · SDC Lab" description="과제 간 방법론·데이터·현장 자원 공유와 공동 실적 기회">
  <section class="mb-6">
    <h1 class="text-2xl font-extrabold tracking-tight text-slate-900 sm:text-[1.7rem]">연구 연계 · 성과 공유</h1>
    {data?.intro && <p class="mt-1.5 max-w-3xl text-sm leading-relaxed text-[var(--muted)]">{data.intro}</p>}
  </section>

  <!-- 연계 맵 -->
  <section class="mb-8">
    <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-500">연계 맵</h2>
    <div class="overflow-x-auto no-scrollbar rounded-2xl border border-[var(--line)] bg-white p-4">
      <div class="relative mx-auto" style="width:600px;height:376px">
        <svg viewBox="0 0 600 376" class="absolute inset-0 h-full w-full">
          {edges.map((e) => (
            <line
              x1={e.A.cx} y1={e.A.cy} x2={e.B.cx} y2={e.B.cy}
              stroke={e.strength === '강' ? '#64748b' : '#cbd5e1'}
              stroke-width={e.strength === '강' ? 2.5 : 1.5}
              stroke-dasharray={e.strength === '강' ? '0' : '6 5'}
            />
          ))}
        </svg>

        {nodeSlugs.map((slug) => {
          const p = posMap[slug];
          const m = meta(slug)!;
          return (
            <a
              href={`${base}projects/${slug}`}
              class="absolute flex flex-col justify-center rounded-xl border border-[var(--line)] bg-white p-3 shadow-sm transition hover:shadow-md"
              style={`left:${p.x}px;top:${p.y}px;width:${NW}px;height:${NH}px;border-top:4px solid ${m.color}`}
            >
              <p class="text-sm font-bold leading-tight text-slate-800">{m.title}</p>
              <p class="mt-1 text-xs text-[var(--muted)]">{m.agency}</p>
            </a>
          );
        })}

        {edges.map((e) => (
          <span
            class={`absolute -translate-x-1/2 -translate-y-1/2 whitespace-nowrap rounded-full border px-2 py-0.5 text-[0.68rem] font-semibold ${e.strength === '강' ? 'border-slate-200 bg-white text-slate-700' : 'border-dashed border-slate-200 bg-white text-slate-400'}`}
            style={`left:${e.mx}px;top:${e.my}px`}
          >{e.theme}</span>
        ))}
      </div>
    </div>
    <div class="mt-2 flex items-center gap-4 text-[0.72rem] text-[var(--muted)]">
      <span class="flex items-center gap-1.5"><svg width="22" height="6"><line x1="0" y1="3" x2="22" y2="3" stroke="#64748b" stroke-width="2.5"/></svg>강한 연계</span>
      <span class="flex items-center gap-1.5"><svg width="22" height="6"><line x1="0" y1="3" x2="22" y2="3" stroke="#cbd5e1" stroke-width="1.5" stroke-dasharray="6 5"/></svg>추가 연계 여지</span>
    </div>
  </section>

  <!-- 연계별 상세 -->
  <section>
    <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-500">연계별 공유 자산 · 공동 실적 기회</h2>
    <div class="space-y-5">
      {sortedLinks.map((l) => (
        <div class="rounded-2xl border border-[var(--line)] bg-white p-5">
          <div class="flex flex-wrap items-center gap-2">
            <span class="inline-flex items-center gap-1.5 rounded-lg bg-slate-50 px-2.5 py-1 text-sm font-semibold text-slate-700"><span class="h-2.5 w-2.5 rounded-full" style={`background:${color(l.a)}`}></span>{short(l.a)}</span>
            <span class="text-slate-300">⇄</span>
            <span class="inline-flex items-center gap-1.5 rounded-lg bg-slate-50 px-2.5 py-1 text-sm font-semibold text-slate-700"><span class="h-2.5 w-2.5 rounded-full" style={`background:${color(l.b)}`}></span>{short(l.b)}</span>
            <span class={`ml-1 rounded-md px-2 py-0.5 text-xs font-bold ${l.strength === '강' ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500'}`}>{l.strength === '강' ? '강한 연계' : '추가 연계'}</span>
          </div>
          <h3 class="mt-2.5 text-[1.02rem] font-bold tracking-tight text-slate-900">{l.title}</h3>

          <div class="mt-4 grid grid-cols-1 gap-3 lg:grid-cols-2">
            <!-- 공유 자산 -->
            <div>
              <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-slate-400">공유 자산</p>
              <ul class="space-y-2.5">
                {l.shared.map((s: any) => (
                  <li class="rounded-xl bg-slate-50 p-3">
                    <div class="mb-1 flex items-center gap-1.5 text-xs font-medium text-slate-500">
                      <span class="inline-flex items-center gap-1"><span class="h-2 w-2 rounded-full" style={`background:${color(s.from)}`}></span>{short(s.from)}</span>
                      <span style={`color:${color(s.from)}`}>→</span>
                      <span class="inline-flex items-center gap-1"><span class="h-2 w-2 rounded-full" style={`background:${color(s.to)}`}></span>{short(s.to)}</span>
                    </div>
                    <p class="text-sm font-semibold text-slate-700">{s.asset}</p>
                    <p class="mt-0.5 text-xs leading-relaxed text-[var(--muted)]">{s.how}</p>
                  </li>
                ))}
              </ul>
            </div>
            <!-- 공동 실적 기회 -->
            <div>
              <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-slate-400">공동 실적 기회</p>
              <ul class="space-y-2">
                {l.outputs.map((o: string) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-0.5 shrink-0 rounded bg-indigo-100 px-1.5 py-0.5 text-[0.62rem] font-bold text-indigo-700">실적</span>
                    <span class="text-sm leading-relaxed text-slate-700">{o}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>
